# Supabase Postgres (pooled connection — used by Prisma at runtime)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase direct connection — used by `prisma migrate` (no pooling)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Supabase Auth — public, sent to the browser
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Server-only — used for admin operations from server code
SUPABASE_SERVICE_ROLE_KEY=""

# Public site URL for OAuth / email confirmation redirects (no trailing slash).
# Local dev:
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Production (Vercel): set to your live URL, e.g. https://your-app.vercel.app
# If left as localhost on Vercel, the app falls back to VERCEL_URL automatically.
